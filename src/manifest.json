{
  "manifest_version": 3,
  "name": "Cesturefy",
  "version": "0.0.1",
  "permissions": ["scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "matches": ["<all_urls>"]
    }
  ]
}
