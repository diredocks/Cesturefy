{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "src",
    "paths": {
      "@utils/*": ["utils/*"],
      "@controller/*": ["controller/*"],
      "@views/*": ["views/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
